# ============================================================
# SuryaVets — Environment Variables Template
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project URL: Settings > API > Project URL
# Format: https://<project-ref>.supabase.co   (NO /rest/v1/ suffix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key: Settings > API > Project API Keys > anon/public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key: Settings > API > Project API Keys > service_role
# KEEP SECRET — only used server-side in admin routes
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Razorpay (optional — required for payments) ───────────────
# https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── App config ────────────────────────────────────────────────
# Production URL (used for OG images, sitemaps, redirects)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# WhatsApp number in international format (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=919820854449

# Free delivery threshold in INR
NEXT_PUBLIC_FREE_DELIVERY_THRESHOLD=499
